<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FileTransformer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary accent (used sparingly, mostly for status dot, icons) -->
        <item name="colorPrimary">@color/gray_900</item>
        <item name="colorPrimaryVariant">@color/gray_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/gray_700</item>
        <item name="colorSecondaryVariant">@color/gray_900</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Surface / Background — pure white -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/gray_900</item>
        <!-- Status bar — white with dark icons -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
