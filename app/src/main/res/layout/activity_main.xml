<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textColor="@color/gray_900"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAN File Transfer"
            android:textSize="13sp"
            android:textColor="@color/gray_500"
            android:layout_marginBottom="28dp" />

        <!-- Status Card — white with subtle border -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray_200"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Status indicator row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:id="@+id/statusIndicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_circle"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_stopped"
                        android:textAppearance="?textAppearanceBody1"
                        android:textColor="@color/gray_500" />
                </LinearLayout>

                <!-- IP Address display -->
                <TextView
                    android:id="@+id/ipAddressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ip_placeholder"
                    android:textAppearance="?textAppearanceHeadline4"
                    android:textColor="@color/gray_900"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Copy Link button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyLinkButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/copy_link"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/gray_700"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Save Location Card — white with subtle border -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray_200"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/save_location"
                        android:textAppearance="?textAppearanceBody2"
                        android:textColor="@color/gray_500"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/saveLocationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/location_downloads"
                        android:textAppearance="?textAppearanceBody1"
                        android:textColor="@color/gray_900" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changeLocationButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/change"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/gray_700"
                    app:strokeColor="@color/gray_300" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Receiving Progress Card — visible during file transfer -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/receivingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray_200"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/receiving"
                        android:textAppearance="?textAppearanceBody2"
                        android:textColor="@color/gray_500" />

                    <TextView
                        android:id="@+id/receivingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?textAppearanceCaption"
                        android:textColor="@color/gray_500" />
                </LinearLayout>

                <TextView
                    android:id="@+id/receivingFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceBody1"
                    android:textColor="@color/gray_900"
                    android:ellipsize="middle"
                    android:singleLine="true"
                    android:layout_marginBottom="10dp" />

                <ProgressBar
                    android:id="@+id/receivingProgressBar"
                    style="?android:progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/gray_900"
                    android:progressBackgroundTint="@color/gray_200" />

                <TextView
                    android:id="@+id/receivingProgressText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?textAppearanceCaption"
                    android:textColor="@color/gray_500"
                    android:gravity="end"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Start/Stop Button — outlined style: white bg + dark border -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startStopButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/start_server"
            android:textSize="16sp"
            android:textColor="@color/gray_900"
            app:cornerRadius="16dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/gray_900"
            app:backgroundTint="@color/white"
            android:layout_marginBottom="28dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_200"
            android:layout_marginBottom="16dp" />

        <!-- Recent Uploads -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/recent_uploads"
            android:textAppearance="?textAppearanceSubtitle1"
            android:textColor="@color/gray_900"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recentUploadsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/noUploadsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_uploads_yet"
            android:textAppearance="?textAppearanceBody2"
            android:textColor="@color/gray_500"
            android:gravity="center"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</ScrollView>
