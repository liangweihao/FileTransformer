<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FileTransformer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/blue_100</item>
        <item name="colorPrimaryVariant">@color/blue_500</item>
        <item name="colorOnPrimary">@color/gray_900</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/blue_100</item>
        <item name="colorSecondaryVariant">@color/blue_50</item>
        <item name="colorOnSecondary">@color/gray_900</item>
        <!-- Surface / Background -->
        <item name="android:colorBackground">@color/gray_900</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/blue_900</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
